{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["AGENTS.md"],

  "plugin": [
    ["token-optimizer-opencode", {
      "qualityWindow": 20,
      "features": {
        "qualityNudges": true,
        "loopDetection": true,
        "smartCompaction": true,
        "continuity": true,
        "activityTracking": true,
        "trends": true
      }
    }]
  ],

  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 4096
  },

  "tool_output": {
    "max_lines": 150,
    "max_bytes": 8192
  },

  "agent": {
    "build": {
      "steps": 30,
      "permission": {
        "bash": { "*": "allow" }
      }
    },
    "plan": {
      "steps": 20,
      "permission": {
        "edit": "deny",
        "bash": { "npm run lint": "allow", "npm test": "allow", "*": "deny" }
      }
    },
    "explore": {
      "steps": 15
    },
    "general": {
      "steps": 20
    }
  },

  "permission": {
    "skill": {
      "*": "allow"
    }
  },

  "snapshot": false,
  "share": "disabled",

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "*.log",
      "logs/**",
      "data/**",
      ".env"
    ]
  }
}
