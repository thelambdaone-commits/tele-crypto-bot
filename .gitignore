sessions.json
sessions.enc

# Logs
logs/
*.log
error_log.txt

# Debug files
debug/

# Build outputs
dist/
build/

# Temporary files
*.tmp
*.temp
.cache/
scratch/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.codex
.opencode/
*.swp
*.swo

# Zip files
*.zip
crypto-bot.zip

# Output logs
output.log
.gitagent/
